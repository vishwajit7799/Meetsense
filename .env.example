# ─────────────────────────────────────────────
# MEETSENSE — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env to GitHub
# ─────────────────────────────────────────────

# Microsoft Azure App Registration
# Create at: https://portal.azure.com > App Registrations
# Permissions needed: Calendars.Read (delegated) — NO admin consent required
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback

# Google Gemini (free) — get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Email delivery — Option A: Gmail app password
# Enable 2FA on Gmail, then: Google Account > Security > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM="MeetSense <your-gmail@gmail.com>"

# PostgreSQL database
# Free options: Railway, Supabase, Neon (all have free tiers)
DATABASE_URL=postgresql://user:password@host:5432/meetsense

# App config
PORT=3000
SESSION_SECRET=change-this-to-a-random-32-char-string
APP_URL=http://localhost:3000

# Bot display name — what participants see in the meeting
BOT_NAME=MeetSense Notetaker
