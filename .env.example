# ─────────────────────────────────────────────
# MEETSENSE v2 — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit your actual .env to GitHub
# ─────────────────────────────────────────────

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# Microsoft OAuth (from portal.azure.com — personal outlook.com account)
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://your-app.onrender.com/auth/microsoft/callback

# Gemini AI (free — https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Razorpay (https://razorpay.com — free to sign up)
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_PLAN_ID=plan_your-plan-id

# Email (Gmail app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=MeetSense <your-gmail@gmail.com>

# Database (Neon free tier)
DATABASE_URL=postgresql://user:password@host:5432/meetsense

# App config
PORT=3000
SESSION_SECRET=change-this-to-a-random-32-char-string
APP_URL=https://your-app.onrender.com
BOT_NAME=MeetSense Notetaker

# Admin access (your email — gives access to admin dashboard)
ADMIN_EMAIL=your-gmail@gmail.com
